# =====================================================================
# SANDR — Environment variables (example)
# Copia in .env.local e compila con i valori reali. NON committare .env.local
# =====================================================================

# ----- App -----------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ----- Supabase ------------------------------------------------------
# Auth + Database (PostgreSQL + RLS)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Solo server-side: NON esporre mai al client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ----- Stripe --------------------------------------------------------
# Abbonamenti + Pay-Per-View
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ----- Cloudflare Stream --------------------------------------------
# Live (RTMP ingest -> HLS delivery) + VOD
# AREA CRITICA (CLAUDE.md): integrazione Cloudflare Stream, review umana.
CLOUDFLARE_ACCOUNT_ID=
# Token API Stream: SOLO server-side, MAI esposto al client
CLOUDFLARE_STREAM_TOKEN=
# Account ID pubblico per l'embed iframe (deve coincidere con CLOUDFLARE_ACCOUNT_ID)
NEXT_PUBLIC_CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_STREAM_API_TOKEN=your-stream-api-token
# Sottodominio di delivery (customer-xxxx.cloudflarestream.com)
NEXT_PUBLIC_CLOUDFLARE_STREAM_CUSTOMER_SUBDOMAIN=customer-xxxx
